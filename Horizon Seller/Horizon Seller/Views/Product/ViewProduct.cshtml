@{
    ViewData["Title"] = "View Product";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - View Product</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --sidebar-bg: #000000;
            --main-bg: #ffffff;
            --box-bg: #AEAFB2; /* Matches the solid gray detail boxes */
            --pill-bg: #AEAFB2;
            --text-dark: #111;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            display: flex;
            min-height: 100vh;
            color: #1a1a1a;
        }

        /* Sidebar Navigation */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .logo {
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 14px 15px;
            color: #999;
            text-decoration: none;
            transition: 0.3s;
            font-weight: 500;
            font-size: 1.1rem;
        }

            .nav-item i {
                margin-right: 15px;
                width: 24px;
                font-size: 1.2rem;
            }

            .nav-item:hover {
                color: #fff;
            }

            .nav-item.active {
                background-color: #333;
                color: #fff;
                border-radius: 10px;
            }

        /* Layout Adjustments */
        .main-wrapper {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
        }

        .header {
            height: 70px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0 50px;
            gap: 30px;
        }

        /* Main View Container */
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 100px 20px;
            width: 100%;
            position: relative;
        }

        .back-btn {
            font-size: 1.5rem;
            color: #111;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 20px;
            transition: 0.2s;
        }

            .back-btn:hover {
                transform: translateX(-5px);
            }

        /* Image Gallery */
        .gallery-container {
            width: 100%;
            height: 550px;
            background-color: #e5e5e5;
            border-radius: 16px;
            position: relative;
            margin-bottom: 15px;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
        }

            .gallery-container img {
                max-width: 100%;
                max-height: 100%;
                object-fit: contain; /* Shows image in actual size without filling box completely */
            }

        /* Clickable halves for image navigation */
        .click-zone {
            position: absolute;
            top: 0;
            bottom: 0;
            width: 50%;
            z-index: 10;
            cursor: pointer;
        }

        .zone-left {
            left: 0;
        }

        .zone-right {
            right: 0;
        }

        .gallery-dots {
            text-align: center;
            margin-bottom: 30px;
            height: 10px;
        }

            .gallery-dots span {
                display: inline-block;
                width: 6px;
                height: 6px;
                background: #ccc;
                border-radius: 50%;
                margin: 0 4px;
                transition: background 0.2s;
            }

                .gallery-dots span.active {
                    background: #111;
                }

        /* Product Details Header Layout */
        .details-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        h3.section-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0; /* Reset margin since wrapper handles spacing */
        }

        /* NEW: Size Guide Link Styling */
        .size-guide-link {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #111;
            text-decoration: none;
            font-weight: lighter;
            font-size: 0.95rem;
            padding: 8px 12px;
            border-radius: 8px;
            transition: background-color 0.2s;
        }

            .size-guide-link:hover {
                background-color: #f0f0f0;
            }

            .size-guide-link i {
                font-size: 1.2rem;
            }


        .info-box {
            background-color: var(--box-bg);
            padding: 16px 20px;
            border-radius: 10px;
            margin-bottom: 15px;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            font-weight: 500;
            color: #111;
            width: 100%;
            box-sizing: border-box;
        }

        /* Variant Row */
        .variant-bar {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-top: 20px;
            margin-bottom: 25px;
            flex-wrap: nowrap;
        }

        .variant-thumb {
            width: 48px;
            height: 48px;
            border-radius: 8px; /* Changed to rounded square */
            object-fit: cover;
        }

        .variant-pill {
            background-color: var(--pill-bg);
            padding: 12px 18px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.9rem;
        }

            .variant-pill .label {
                color: #555;
            }

            .variant-pill .divider {
                width: 1px;
                height: 16px;
                background-color: #333;
            }

            .variant-pill .value {
                font-weight: 700;
                color: #111;
            }

        .availability-label {
            font-weight: 700;
            font-size: 0.95rem;
            margin-left: 20px; /* Reduced huge gap spacing */
            margin-right: 10px;
        }

        .radio-stack {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .custom-radio {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            font-size: 0.85rem;
            color: #111;
        }

        .radio-box {
            width: 20px;
            height: 20px;
            border-radius: 4px;
        }

        .box-active {
            background-color: #000;
        }

        .box-inactive {
            background-color: var(--box-bg);
        }

        /* Description & Barcode Split */
        .bottom-details {
            display: flex;
            gap: 15px;
            margin-bottom: 30px;
        }

        .description-box {
            flex: 1;
            background-color: var(--box-bg);
            padding: 25px;
            border-radius: 12px;
            line-height: 1.5;
            font-size: 0.9rem;
            color: #111;
        }

            .description-box ul {
                margin-top: 15px;
                padding-left: 20px;
                margin-bottom: 0;
            }

            .description-box li {
                margin-bottom: 5px;
            }

        .barcode-box {
            width: 220px;
            background-color: var(--box-bg);
            padding: 20px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            font-weight: 700;
            font-size: 1rem;
        }

            .barcode-box svg {
                width: 100%;
                height: 70px;
                margin: 15px 0;
            }

        /* Dynamic Action Buttons */
        .action-bar {
            display: flex;
            gap: 15px;
            justify-content: space-between;
        }

        .btn-action {
            padding: 18px 0;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            font-weight: 500;
            text-align: center;
            cursor: pointer;
            transition: 0.2s;
            display: none; /* hidden by default, toggled via JS */
        }

        .btn-delete {
            background-color: transparent;
            border: 1px solid #111;
            color: #111;
            flex: 1;
        }

            .btn-delete:hover {
                background-color: #f5f5f5;
            }

        .btn-edit, .btn-renew {
            background-color: #1a1a1a;
            border: none;
            color: #fff;
            flex: 1;
        }

            .btn-edit:hover, .btn-renew:hover {
                background-color: #000;
            }

        .btn-relist {
            background-color: #555555;
            border: none;
            color: #fff;
        }

            .btn-relist:hover {
                background-color: #333;
            }

        /* OVERLAY MODAL STYLING (For Delete Pop Up) */
        .overlay-modal {
            display: none; /* Hidden by default */
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .delete-modal-content {
            background: #fff;
            padding: 40px 30px;
            border-radius: 16px;
            max-width: 450px;
            width: 90%;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }

        .btn-modal-outline {
            flex: 1;
            padding: 15px 0;
            border: 1px solid #000;
            background: #fff;
            color: #000;
            border-radius: 10px;
            font-weight: 500;
            font-size: 1rem;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: 0.2s;
        }

            .btn-modal-outline:hover {
                background: #f5f5f5;
            }

        .btn-modal-solid {
            flex: 1;
            padding: 15px 0;
            border: 1px solid #000;
            background: #000;
            color: #fff;
            border-radius: 10px;
            font-weight: 500;
            font-size: 1rem;
            cursor: pointer;
            font-family: 'Inter', sans-serif;
            transition: 0.2s;
        }

            .btn-modal-solid:hover {
                background: #333;
            }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <div style="background: white; color: black; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <nav>
            <a href="#" class="nav-item"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-receipt"></i> Orders</a>
            <a href="#" class="nav-item active"><i class="fa-solid fa-bag-shopping"></i> Products</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-wallet"></i> Finances</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-chart-line"></i> Analytics</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="header">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </header>

        <div class="container">
            <a href="javascript:window.history.back()" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>

            <div class="gallery-container">
