@{
    ViewData["Title"] = "Manage Products";
    Layout = null;
    // We can keep these variables, but the actual counts are now dynamically updated by JavaScript
    // based on how many products are actually in the containers!
    var activeCount = 0;
    var renewCount = 0;
    var relistCount = 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Manage Products</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/Index.css">
</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <div style="background: white; color: black; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <nav>
            <a href="#" class="nav-item"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-receipt"></i> Orders</a>
            <a href="#" class="nav-item active"><i class="fa-solid fa-bag-shopping"></i> Products</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-wallet"></i> Finances</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-chart-line"></i> Analytics</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="header">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </header>

        <div class="content-container">
            <div class="profile-section">
                <div class="profile-circle">
                    <i class="fa-regular fa-user" style="font-size: 2.5rem; color: #ccc;"></i>
                </div>
                <div class="profile-text">
                    <h1>Manage your products with ease.</h1>
                    <p>Track, update, and grow your sales in one place.</p>
                </div>
            </div>

            <hr />

            <button class="btn-create" onclick="window.location.href='/Product/Create'">
                <i class="fa-solid fa-plus"></i> Create Product Listing
            </button>

            <h2 style="font-size: 1.4rem; font-weight: 800; margin-bottom: 20px;">Overview</h2>

            <div class="overview-grid">
                <div class="overview-card active-card" onclick="changeTab('active', this)">
                    <span>Active<br>Product</span>
                    <div class="badge" id="badge-active" style="background: var(--accent-green);">@activeCount</div>
                </div>
                <div class="overview-card" onclick="changeTab('renew', this)">
                    <span>Renew<br>Product</span>
                    <div class="badge" id="badge-renew" style="background: var(--accent-yellow);">@renewCount</div>
                </div>
                <div class="overview-card" onclick="changeTab('relist', this)">
                    <span>Relist Deleted<br>Product</span>
                    <div class="badge" id="badge-relist" style="background: var(--accent-red);">@relistCount</div>
                </div>
            </div>

            <div class="product-box">
                <div class="product-header">
                    <h3 id="display-title" style="font-weight: 700; font-size: 1.1rem; margin: 0;">Active Product</h3>
                    <div class="header-actions">
                        <button class="btn-action-pill" onclick="window.location.href='/Promotions/Promotion'">Add Promotion</button>
                        <select class="filter-dropdown-select" id="categoryFilter" onchange="filterProducts()">
                            <option value="All">All</option>
                        </select>
                    </div>
                </div>

                <div id="active-content" class="product-group visible">
                    <div class="product-row">
                        <div class="product-detail">
                            <a href="/Product/ViewProduct?state=active">
                                <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff" class="product-img" alt="Product">
                            </a>
                            <div class="product-info">
                                <a href="/Product/ViewProduct?state=active">
                                    <h4>Sabrina 3 EP</h4>
                                </a>
                                <p>Basketball Shoes</p>
                                <div class="price-wrap">
                                    <span class="price">₱7,595</span>
                                    <span class="old-price">- ₱9,493.75</span>
                                </div>
                                <a href="/Product/ViewRatings" class="rating-pill">
                                    <span class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i></span>
                                    <span class="review-text">- 20 Reviews</span>
                                </a>
                            </div>
                        </div>
                        <div class="action-menu-container">
                            <button class="btn-ellipses" onclick="toggleMenu(event, this)">
                                <i class="fa-solid fa-ellipsis"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a href="/Product/ViewProduct?state=active" class="dropdown-item">View Product</a>
                                <a href="/Product/Create?mode=edit" class="dropdown-item">Edit Product</a>
                            </div>
                        </div>
                    </div>
                    <div class="product-row">
                        <div class="product-detail">
                            <a href="/Product/ViewProduct?state=active">
                                <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a" class="product-img" alt="Product">
                            </a>
                            <div class="product-info">
                                <a href="/Product/ViewProduct?state=active">
                                    <h4>Nike Sportswear</h4>
                                </a>
                                <p>Women's Oversized Windrunner Jacket</p>
                                <div class="price-wrap">
                                    <span class="price">₱4,795</span>
                                </div>
                                <a href="/Product/ViewRatings" class="rating-pill">
                                    <span class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></span>
                                    <span class="review-text">- 10K Reviews</span>
                                </a>
                            </div>
                        </div>
                        <div class="action-menu-container">
                            <button class="btn-ellipses" onclick="toggleMenu(event, this)">
                                <i class="fa-solid fa-ellipsis"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a href="/Product/ViewProduct?state=active" class="dropdown-item">View Product</a>
                                <a href="/Product/Create?mode=edit" class="dropdown-item">Edit Product</a>
                            </div>
                        </div>
                    </div>
                    <div class="product-row">
                        <div class="product-detail">
                            <a href="/Product/ViewProduct?state=active">
                                <img src="https://images.unsplash.com/photo-1556821840-3a63f95609a7" class="product-img" alt="Product">
                            </a>
                            <div class="product-info">
                                <a href="/Product/ViewProduct?state=active">
                                    <h4>ACG 'Smith Summit'</h4>
                                </a>
                                <p>Older Kids' Trousers</p>
                                <div class="price-wrap">
                                    <span class="price">₱3,695</span>
                                </div>
                                <a href="/Product/ViewRatings" class="rating-pill">
                                    <span class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></span>
                                    <span class="review-text">- 1K Reviews</span>
                                </a>
                            </div>
                        </div>
                        <div class="action-menu-container">
                            <button class="btn-ellipses" onclick="toggleMenu(event, this)">
                                <i class="fa-solid fa-ellipsis"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a href="/Product/ViewProduct?state=active" class="dropdown-item">View Product</a>
                                <a href="/Product/Create?mode=edit" class="dropdown-item">Edit Product</a>
                            </div>
                        </div>
                    </div>
                    <div class="product-row">
                        <div class="product-detail">
                            <a href="/Product/ViewProduct?state=active">
                                <img src="https://images.unsplash.com/photo-1515955656352-a1fa3ffcd111" class="product-img" alt="Product">
                            </a>
                            <div class="product-info">
                                <a href="/Product/ViewProduct?state=active">
                                    <h4>Jordan Flight Club '91</h4>
                                </a>
                                <p>Men's Shoes</p>
                                <div class="price-wrap">
                                    <span class="price">₱6,895</span>
                                </div>
                                <a href="/Product/ViewRatings" class="rating-pill">
                                    <span class="stars"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i></span>
                                    <span class="review-text">- 340 Reviews</span>
                                </a>
                            </div>
                        </div>
                        <div class="action-menu-container">
                            <button class="btn-ellipses" onclick="toggleMenu(event, this)">
                                <i class="fa-solid fa-ellipsis"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a href="/Product/ViewProduct?state=active" class="dropdown-item">View Product</a>
                                <a href="/Product/Create?mode=edit" class="dropdown-item">Edit Product</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="renew-content" class="product-group">
                    <div class="product-row">
                        <div class="product-detail">
                            <a href="/Product/ViewProduct?state=renew">
                                <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a" class="product-img">
                            </a>
                            <div class="product-info">
                                <a href="/Product/ViewProduct?state=renew">
                                    <h4>Sportswear Collection</h4>
                                </a>
                                <p>Older Kids' Denim Jacket</p>
                                <div class="price-wrap">
                                    <span class="price">₱3,295</span>
                                </div>
                            </div>
                        </div>
                        <div class="action-menu-container">
                            <button class="btn-ellipses" onclick="toggleMenu(event, this)">
                                <i class="fa-solid fa-ellipsis"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a href="/Product/ViewProduct?state=renew" class="dropdown-item">View Product</a>
                                <a href="/Product/Create?mode=renew" class="dropdown-item">Renew Product</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="relist-content" class="product-group">
                    <div class="product-row">
                        <div class="product-detail">
                            <a href="/Product/ViewProduct?state=relist">
                                <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff" class="product-img" style="filter:grayscale(1)">
                            </a>
                            <div class="product-info">
                                <a href="/Product/ViewProduct?state=relist">
                                    <h4>Nike Burrow</h4>
                                </a>
                                <p>Men's Slipper (Deleted)</p>
                                <div class="price-wrap">
                                    <span class="price">₱2,595</span>
                                </div>
                            </div>
                        </div>
                        <div class="action-menu-container">
                            <button class="btn-ellipses" onclick="toggleMenu(event, this)">
                                <i class="fa-solid fa-ellipsis"></i>
                            </button>
                            <div class="dropdown-menu">
                                <a href="/Product/ViewProduct?state=relist" class="dropdown-item">View Product</a>
                                <a href="/Product/Create?mode=relist" class="dropdown-item">Relist Product</a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pagination">
                    <i class="fa-solid fa-chevron-left nav-arrow disabled"></i>
                    <span class="page-active">1</span>
                    <i class="fa-solid fa-chevron-right nav-arrow disabled"></i>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 1. Function to dynamically count products and update the overview badges
        function updateProductCounts() {
            var activeCount = document.querySelectorAll('#active-content .product-row').length;
            var renewCount = document.querySelectorAll('#renew-content .product-row').length;
            var relistCount = document.querySelectorAll('#relist-content .product-row').length;

            document.getElementById('badge-active').innerText = activeCount;
            document.getElementById('badge-renew').innerText = renewCount;
            document.getElementById('badge-relist').innerText = relistCount;
        }

        // Run counts and initialize dynamic category filter on load
        document.addEventListener("DOMContentLoaded", function () {
            updateProductCounts();
            populateCategories(); // Fill the dropdown based on default active tab
        });

        // 2. Tab Changing Logic
        function changeTab(tabId, element) {
            // Reset all cards styling
            var cards = document.getElementsByClassName('overview-card');
            for (var i = 0; i < cards.length; i++) {
                cards[i].classList.remove('active-card');
            }

            // Highlight clicked card
            element.classList.add('active-card');

            // Hide all product groups
            var groups = document.getElementsByClassName('product-group');
            for (var j = 0; j < groups.length; j++) {
                groups[j].classList.remove('visible');
            }

            // Show the selected group
            document.getElementById(tabId + '-content').classList.add('visible');

            // Update the list title
            var titles = {
                'active': 'Active Product',
                'renew': 'Renew Product',
                'relist': 'Relist Deleted Product'
            };
            document.getElementById('display-title').innerText = titles[tabId];

            // Update filters for the newly visible tab
            populateCategories();
            filterProducts(); // Ensure all products are shown when changing tabs initially
        }

        // 3. Dropdown Menu Toggle Logic
        function toggleMenu(event, buttonElement) {
            // Prevent the click from triggering the window.onclick event below immediately
            event.stopPropagation();

            // First, close any other dropdowns that might be open
            var allDropdowns = document.getElementsByClassName("dropdown-menu");
            for (var i = 0; i < allDropdowns.length; i++) {
                if (allDropdowns[i] !== buttonElement.nextElementSibling) {
                    allDropdowns[i].classList.remove('show');
                }
            }

            // Toggle the dropdown right next to the clicked button
            var menu = buttonElement.nextElementSibling;
            menu.classList.toggle("show");
        }

        // 4. Close dropdown if the user clicks anywhere else on the screen
        window.onclick = function(event) {
            if (!event.target.matches('.btn-ellipses') && !event.target.closest('.btn-ellipses')) {
                var dropdowns = document.getElementsByClassName("dropdown-menu");
                for (var i = 0; i < dropdowns.length; i++) {
                    var openDropdown = dropdowns[i];
                    if (openDropdown.classList.contains('show')) {
                        openDropdown.classList.remove('show');
                    }
                }
            }
        }

        // 5. Dynamic Category Filter System
        function populateCategories() {
            const filterSelect = document.getElementById('categoryFilter');
            filterSelect.innerHTML = '<option value="All">All</option>'; // Reset dropdown

            const activeGroup = document.querySelector('.product-group.visible');
            if (!activeGroup) return;

            // Extract unique categories from the <p> tags under product-info
            const categories = new Set();
            const rows = activeGroup.querySelectorAll('.product-row');

            rows.forEach(row => {
                const categoryText = row.querySelector('.product-info p').innerText.trim();
                row.setAttribute('data-category', categoryText); // Temporarily store on row for easy filtering
                categories.add(categoryText);
            });

            // Populate Dropdown
            categories.forEach(category => {
                const option = document.createElement('option');
                option.value = category;
                option.innerText = category;
                filterSelect.appendChild(option);
            });
        }

        function filterProducts() {
            const selectedCategory = document.getElementById('categoryFilter').value;
            const activeGroup = document.querySelector('.product-group.visible');
            const rows = activeGroup.querySelectorAll('.product-row');

            rows.forEach(row => {
                // Determine if it matches the current selected category, or "All"
                if (selectedCategory === "All" || row.getAttribute('data-category') === selectedCategory) {
                    row.style.display = "flex"; // "flex" is the display property you set for .product-row
                } else {
                    row.style.display = "none";
                }
            });
        }
    </script>

</body>
</html>