                        <rect x="80" y="0" width="8" height="80" fill="#000" />
                        <rect x="92" y="0" width="3" height="80" fill="#000" />
                        <rect x="98" y="0" width="6" height="80" fill="#000" />
                        <rect x="108" y="0" width="2" height="80" fill="#000" />
                        <rect x="114" y="0" width="10" height="80" fill="#000" />
                        <rect x="128" y="0" width="4" height="80" fill="#000" />
                        <rect x="135" y="0" width="5" height="80" fill="#000" />
                        <rect x="144" y="0" width="2" height="80" fill="#000" />
                        <rect x="150" y="0" width="8" height="80" fill="#000" />
                        <rect x="162" y="0" width="3" height="80" fill="#000" />
                        <rect x="168" y="0" width="6" height="80" fill="#000" />
                        <rect x="178" y="0" width="2" height="80" fill="#000" />
                        <rect x="183" y="0" width="10" height="80" fill="#000" />
                        <rect x="196" y="0" width="4" height="80" fill="#000" />
                    </svg>
                    67972 4791 648
                </div>
            </div>

            <div class="action-bar" id="actionBar">
                <button class="btn-action btn-delete" id="btnDelete" onclick="document.getElementById('deleteModal').style.display='flex'">Delete Product</button>
                <button class="btn-action btn-renew" id="btnRenew" onclick="window.location.href='/Product/Create?mode=renew'">Renew Product</button>
                <button class="btn-action btn-edit" id="btnEdit" onclick="window.location.href='/Product/Create?mode=edit'">Edit Product</button>
                <button class="btn-action btn-relist" id="btnRelist" onclick="window.location.href='/Product/Create?mode=relist'">Relist Product</button>
            </div>

        </div>
    </div>

    <div class="overlay-modal" id="deleteModal">
        <div class="delete-modal-content">
            <i class="fa-solid fa-trash" style="font-size: 4rem; color: #000; margin-bottom: 20px;"></i>
            <h2 style="margin: 0 0 15px 0; font-size: 1.8rem; font-weight: 700;">Delete Products</h2>
            <p style="margin: 0 0 30px 0; font-size: 1.1rem; color: #333;">Are you sure that you want to delete this product?</p>
            <div style="display: flex; gap: 15px; width: 100%;">
                <button class="btn-modal-outline" onclick="window.location.href='index.cshtml'">Delete Product</button>
                <button class="btn-modal-solid" onclick="document.getElementById('deleteModal').style.display='none'">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        /* --- Image Gallery Logic --- */
        // Array of images to simulate a gallery. You can add as many as you want here.
        const galleryImages = [
            "https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a", // Front
            "https://images.unsplash.com/photo-1608228065096-7b4474776150", // Close up
            "https://images.unsplash.com/photo-1489987707023-afc82478163f", // Detail
            "https://images.unsplash.com/photo-1556821840-3a63f95609a7", // Extra
            "https://images.unsplash.com/photo-1515955656352-a1fa3ffcd111"  // 5th photo (dots will max at 4)
        ];

        let currentImageIndex = 0;
        const mainGalleryImg = document.getElementById('mainGalleryImg');
        const dotsContainer = document.getElementById('galleryDots');

        function renderGallery() {
            // Update image source
            mainGalleryImg.src = galleryImages[currentImageIndex];

            // Render Dots (Max 4 visible)
            dotsContainer.innerHTML = '';
            const totalDots = Math.min(galleryImages.length, 4);

            // Calculate which dot should be active
            let activeDotIndex = currentImageIndex;
            if (currentImageIndex >= 3 && galleryImages.length > 4) {
                activeDotIndex = 3; // Keep the last dot active for the 4th, 5th, 6th image etc.
            }

            for (let i = 0; i < totalDots; i++) {
                const dot = document.createElement('span');
                if (i === activeDotIndex) {
                    dot.classList.add('active');
                }
                dotsContainer.appendChild(dot);
            }
        }

        function nextImage() {
            if (galleryImages.length > 0) {
                currentImageIndex = (currentImageIndex + 1) % galleryImages.length;
                renderGallery();
            }
        }

        function prevImage() {
            if (galleryImages.length > 0) {
                currentImageIndex = (currentImageIndex - 1 + galleryImages.length) % galleryImages.length;
                renderGallery();
            }
        }

        /* --- Dynamic Button Logic based on URL State --- */
        document.addEventListener('DOMContentLoaded', () => {
            // Initialize Gallery
            renderGallery();

            // Initialize Buttons
            const urlParams = new URLSearchParams(window.location.search);
            const state = urlParams.get('state'); // Checks for ?state=active, ?state=renew, etc.

            const actionBar = document.getElementById('actionBar');
            const btnDelete = document.getElementById('btnDelete');
            const btnRenew = document.getElementById('btnRenew');
            const btnEdit = document.getElementById('btnEdit');
            const btnRelist = document.getElementById('btnRelist');

            // Hide all first
            btnDelete.style.display = 'none';
            btnRenew.style.display = 'none';
            btnEdit.style.display = 'none';
            btnRelist.style.display = 'none';

            if (state === 'renew') {
                // Renew State: Only Delete and Renew (evenly split 50/50)
                btnDelete.style.display = 'block';
                btnRenew.style.display = 'block';
            } else if (state === 'relist') {
                // Relist State: ONLY Relist button, formatted to sit on the right side
                actionBar.style.justifyContent = 'flex-end';
                btnRelist.style.display = 'block';
                btnRelist.style.flex = '0 0 48%'; // Forces it to take up about half the screen on the right
            } else {
                // Default / Active State: Only Delete and Edit (evenly split 50/50)
                btnDelete.style.display = 'block';
                btnEdit.style.display = 'block';
            }
        });
    </script>

</body>
</html>

