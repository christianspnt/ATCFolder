@{
    ViewData["Title"] = "View Ratings";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - View Ratings</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --sidebar-bg: #000000;
            --main-bg: #ffffff;
            --text-dark: #111111;
            --text-gray: #555555;
            --filter-bg: #B0B3B8;
            --filter-hover: #9CA0A5;
            --border-color: #E0E0E0;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            display: flex;
            min-height: 100vh;
            color: var(--text-dark);
        }

        /* Sidebar Navigation */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .logo {
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 14px 15px;
            color: #999;
            text-decoration: none;
            transition: 0.3s;
            font-weight: 500;
            font-size: 1.1rem;
        }

            .nav-item i {
                margin-right: 15px;
                width: 24px;
                font-size: 1.2rem;
            }

            .nav-item:hover {
                color: #fff;
            }

            .nav-item.active {
                background-color: #333;
                color: #fff;
                border-radius: 10px;
            }

        /* Layout Adjustments */
        .main-wrapper {
            flex: 1;
            margin-left: 300px;
            display: flex;
            flex-direction: column;
        }

        .header {
            height: 70px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0 50px;
            gap: 30px;
        }

        .content-container {
            padding: 40px 80px;
            max-width: 1000px;
        }

        /* Back Button & Title */
        .page-title-row {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 40px;
        }

        .back-btn {
            font-size: 1.5rem;
            color: #000;
            text-decoration: none;
            cursor: pointer;
        }

        .page-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin: 0;
        }

        /* Product Summary Header */
        .product-summary {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }

        .product-info-wrap {
            display: flex;
            gap: 20px;
            align-items: center;
            flex: 1;
        }

        .product-img {
            width: 110px;
            height: 110px;
            border-radius: 12px;
            object-fit: cover;
        }

        .product-text h2 {
            margin: 0;
            font-size: 1.3rem;
            font-weight: 700;
        }

        .product-text p {
            margin: 5px 0 15px 0;
            font-size: 0.95rem;
            color: var(--text-dark);
        }

        .price-wrap {
            display: flex;
            gap: 6px;
            font-size: 0.9rem;
        }

            .price-wrap .current-price {
                font-weight: 700;
                color: #000;
            }

            .price-wrap .old-price {
                color: #888;
                text-decoration: line-through;
            }

        .stats-wrap {
            display: flex;
            gap: 70px;
            text-align: center;
            padding-right: 20px;
        }

        .stat-box h3 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 700;
            color: #000;
        }

        .stat-box .stat-value {
            font-size: 3.5rem;
            font-weight: 700;
            margin: 5px 0;
            line-height: 1;
        }

        .stat-box p {
            margin: 0;
            font-size: 0.9rem;
            color: var(--text-gray);
        }

        .stat-stars {
            color: #000;
            font-size: 1rem;
        }

        /* Filter Bar */
        .filter-bar {
            display: flex;
            gap: 15px;
            margin-bottom: 60px;
        }

        .filter-btn, .filter-select {
            background-color: var(--filter-bg);
            color: #111;
            border: none;
            border-radius: 10px;
            padding: 14px 20px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
            flex: 1;
            text-align: center;
            outline: none;
        }

            .filter-btn:hover, .filter-select:hover {
                background-color: var(--filter-hover);
            }

        /* Custom Dropdown Arrow */
        .filter-select {
            appearance: none;
            -webkit-appearance: none;
            background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20320%20512%22%3E%3Cpath%20fill%3D%22%23FFFFFF%22%20d%3D%22M137.4%20374.6c12.5%2012.5%2032.8%2012.5%2045.3%200l128-128c9.2-9.2%2011.9-22.9%206.9-34.9s-16.6-19.8-29.6-19.8L32%20192c-12.9%200-24.6%207.8-29.6%2019.8s-2.2%2025.7%206.9%2034.9l128%20128z%22%2F%3E%3C%2Fsvg%3E');
            background-repeat: no-repeat;
            background-position: right 20px center;
            background-size: 12px auto;
        }

        /* Drop Shadow Active State */
        .filter-btn.active {
            background-color: #FFFFFF;
            box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15), 0px 1px 3px rgba(0, 0, 0, 0.1);
            color: #000;
        }

        /* Review List & Cards */
        .review-list {
            display: flex;
            flex-direction: column;
        }

        .review-card {
            display: flex;
            flex-direction: column;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 35px;
            margin-bottom: 35px;
        }

            .review-card:last-child {
                border-bottom: none;
                margin-bottom: 0;
            }

        .review-top-row {
            display: flex;
            gap: 30px;
        }

        /* Reviewer Details (Side by Side) */
        .reviewer-meta {
            width: 250px;
            display: flex;
            flex-direction: row;
            gap: 30px;
        }

        .reviewer-avatar {
            width: 75px;
            height: 75px;
            border-radius: 50%;
            object-fit: cover;
        }

        .reviewer-details {
            display: flex;
            flex-direction: column;
        }

        .reviewer-name {
            font-weight: 700;
            font-size: 1.05rem;
            margin: 0 0 2px 0;
            color: #000;
        }

        .reviewer-date {
            color: var(--text-gray);
            font-size: 0.85rem;
            margin: 0 0 10px 0;
        }

        .reviewer-variation {
            font-size: 0.85rem;
            color: var(--text-dark);
            margin: 0;
        }

        .review-content {
            flex: 1;
            padding-top: 5px;
            margin-left: 50px;
        }

        .review-stars {
            font-size: 1rem;
            color: #000;
            margin-bottom: 8px;
            letter-spacing: 1px;
        }

        .review-text {
            font-size: 0.95rem;
            line-height: 1.5;
            color: #111;
            margin: 0;
            max-width: 650px;
        }

        /* Review Bottom Row (Actions) */
        .review-actions-row {
            display: flex;
            gap: 30px;
            margin-top: 15px;
            align-items: center;
        }

        .action-left {
            width: 250px; /* Aligns with reviewer-meta block */
        }

        .btn-view-photos {
            background-color: #E2E3E5;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.9rem;
            color: #000;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-view-photos:hover {
                background-color: #D1D3D6;
            }

        .action-right {
            flex: 1;
            display: flex;
            align-items: center;
            gap: 20px;
            max-width: 650px;
            margin-left: 50px;
        }

        .reply-input {
            flex: 1;
            padding: 14px 20px;
            border: 1px solid #CCC;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            outline: none;
            transition: border 0.2s;
        }

            .reply-input:focus {
                border-color: #888;
            }

        .btn-send {
            background: none;
            border: none;
            font-size: 1.5rem;
            color: #000;
            cursor: pointer;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.2s;
        }

            .btn-send:hover {
                transform: scale(1.1);
            }

        /* PHOTO MODAL LIGHTBOX STYLES */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.85);
            backdrop-filter: blur(4px);
        }

        .modal-content {
            position: relative;
            margin: 5% auto;
            width: 80%;
            max-width: 700px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 80vh;
        }

        #modalImage {
            max-width: 100%;
            max-height: 100%;
            border-radius: 12px;
            object-fit: contain;
            box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        }

        .close-modal {
            position: absolute;
            top: 20px;
            right: 40px;
            color: white;
            font-size: 40px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

            .close-modal:hover {
                color: #bbb;
            }

        .modal-controls {
            margin-top: 20px;
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .modal-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            font-size: 1rem;
            transition: 0.3s;
        }

            .modal-btn:hover {
                background: rgba(255,255,255,0.4);
            }

        #imageCounter {
            color: white;
            font-size: 1rem;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <div style="background: white; color: black; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <nav>
            <a href="#" class="nav-item"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-receipt"></i> Orders</a>
            <a href="/Product/Index" class="nav-item active"><i class="fa-solid fa-bag-shopping"></i> Products</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-wallet"></i> Finances</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-chart-line"></i> Analytics</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="header">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </header>

        <div class="content-container">

            <div class="page-title-row">
                <a href="/Home/Index" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>
                <h1 class="page-title">Reviews</h1>
            </div>

            <div class="product-summary">
                <div class="product-info-wrap">
                    <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff" alt="Product" class="product-img">
                    <div class="product-text">
                        <h2>Sabrina 3 EP</h2>
                        <p>Basketball Shoes</p>
                        <div class="price-wrap">
                            <span class="current-price">₱7,595</span>
                            <span class="old-price">- ₱9,493.75</span>
                        </div>
                    </div>
                </div>

                <div class="stats-wrap">
                    <div class="stat-box">
                        <h3>Total Review</h3>
                        <div class="stat-value">9.5K</div>
                        <p>Top-rated by our community</p>
                    </div>
                    <div class="stat-box">
                        <h3>Average Rating</h3>
                        <div class="stat-value">4.9</div>
                        <div class="stat-stars">
                            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star-half-stroke"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="filter-bar">
                <button class="filter-btn active" id="btnFilterAll" onclick="setActiveFilter(this)">All</button>
                <button class="filter-btn" id="btnFilterMedia" onclick="setActiveFilter(this)">With Media</button>

                <select class="filter-select" id="starFilter" onchange="applyFilters()">
                    <option value="all">Star (All)</option>
                    <option value="5">5 Stars ★★★★★</option>
                    <option value="4">4 Stars ★★★★☆</option>
                    <option value="3">3 Stars ★★★☆☆</option>
                    <option value="2">2 Stars ★★☆☆☆</option>
                    <option value="1">1 Star ★☆☆☆☆</option>
                </select>

                <select class="filter-select" id="variationFilter" onchange="applyFilters()">
                    <option value="all">Variation</option>
                    <option value="xl-black">XL - Black</option>
                    <option value="l-black">L - Black</option>
                    <option value="m-black">M - Black</option>
                </select>
            </div>

            <div class="review-list">

                <div class="review-card" data-rating="5" data-media="true" data-variation="xl-black">
                    <div class="review-top-row">
                        <div class="reviewer-meta">
                            <img src="https://images.unsplash.com/photo-1618077360395-f3068be8e001?q=80&w=200&auto=format&fit=crop" alt="User" class="reviewer-avatar">
                            <div class="reviewer-details">
                                <p class="reviewer-name">Carlos Y.</p>
                                <p class="reviewer-date">03-12-2026</p>
                                <p class="reviewer-variation">XL - Black 1qty</p>
                            </div>
                        </div>
                        <div class="review-content">
                            <div class="review-stars">
                                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                            </div>
                            <p class="review-text">
                                "After using this for a week, I can honestly say the build quality exceeds every expectation I had for a product at this price point."
                            </p>
                        </div>
                    </div>
                    <div class="review-actions-row">
                        <div class="action-left">
                            <button class="btn-view-photos" onclick="openPhotoModal(['https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?q=80&w=800&auto=format&fit=crop', 'https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?q=80&w=800&auto=format&fit=crop'])">
                                View 2 Photos
                            </button>
                        </div>
                        <div class="action-right">
                            <input type="text" class="reply-input" placeholder="Write a reply...">
                            <button class="btn-send"><i class="fa-solid fa-paper-plane"></i></button>
                        </div>
                    </div>
                </div>

                <div class="review-card" data-rating="4" data-media="false" data-variation="l-black">
                    <div class="review-top-row">
                        <div class="reviewer-meta">
                            <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?q=80&w=200&auto=format&fit=crop" alt="User" class="reviewer-avatar">
                            <div class="reviewer-details">
                                <p class="reviewer-name">Marcus T.</p>
                                <p class="reviewer-date">03-10-2026</p>
                                <p class="reviewer-variation">L - Black 1qty</p>
                            </div>
                        </div>
                        <div class="review-content">
                            <div class="review-stars">
                                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i>
                            </div>
                            <p class="review-text">
                                "Good quality, but it runs slightly smaller than I expected. Still comfortable enough to wear during workouts though."
                            </p>
                        </div>
                    </div>
                    <div class="review-actions-row">
                        <div class="action-left">
                        </div>
                        <div class="action-right">
                            <input type="text" class="reply-input" placeholder="Write a reply...">
                            <button class="btn-send"><i class="fa-solid fa-paper-plane"></i></button>
                        </div>
                    </div>
                </div>

                <div class="review-card" data-rating="5" data-media="true" data-variation="m-black">
                    <div class="review-top-row">
                        <div class="reviewer-meta">
                            <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=200&auto=format&fit=crop" alt="User" class="reviewer-avatar">
                            <div class="reviewer-details">
                                <p class="reviewer-name">Sarah J.</p>
                                <p class="reviewer-date">03-05-2026</p>
                                <p class="reviewer-variation">M - Black 2qty</p>
                            </div>
                        </div>
                        <div class="review-content">
                            <div class="review-stars">
                                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                            </div>
                            <p class="review-text">
                                "Absolutely love it! Best purchase I've made this year. The material feels premium."
                            </p>
                        </div>
                    </div>
                    <div class="review-actions-row">
                        <div class="action-left">
                            <button class="btn-view-photos" onclick="openPhotoModal(['https://images.unsplash.com/photo-1542291026-7eec264c27ff?q=80&w=800&auto=format&fit=crop'])">
                                View 1 Photo
                            </button>
                        </div>
                        <div class="action-right">
                            <input type="text" class="reply-input" placeholder="Write a reply...">
                            <button class="btn-send"><i class="fa-solid fa-paper-plane"></i></button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <div id="photoModal" class="modal">
        <span class="close-modal" onclick="closeModal()">&times;</span>
        <div class="modal-content">
            <img id="modalImage" src="">
            <div class="modal-controls">
                <button class="modal-btn" onclick="changePhoto(-1)"><i class="fa-solid fa-chevron-left"></i></button>
                <span id="imageCounter">1 / 2</span>
                <button class="modal-btn" onclick="changePhoto(1)"><i class="fa-solid fa-chevron-right"></i></button>
            </div>
        </div>
    </div>

    <script>
        // --- FILTERING LOGIC ---
        function applyFilters() {
            const starValue = document.getElementById('starFilter').value;
            const variationValue = document.getElementById('variationFilter').value;
            const isMediaActive = document.getElementById('btnFilterMedia').classList.contains('active');

            const reviews = document.querySelectorAll('.review-card');

            reviews.forEach(card => {
                const cardRating = card.getAttribute('data-rating');
                const cardMedia = card.getAttribute('data-media') === 'true';
                const cardVariation = card.getAttribute('data-variation');

                let shouldShow = true;

                // 1. Check Media Filter
                if (isMediaActive && !cardMedia) {
                    shouldShow = false;
                }

                // 2. Check Star Filter
                if (starValue !== 'all' && cardRating !== starValue) {
                    shouldShow = false;
                }

                // 3. Check Variation Filter
                if (variationValue !== 'all' && cardVariation !== variationValue) {
                    shouldShow = false;
                }

                // Apply display property
                if (shouldShow) {
                    card.style.display = 'flex';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        // --- FILTER BUTTON TOGGLE ---
        function setActiveFilter(clickedBtn) {
            // Remove active class from buttons
            document.getElementById('btnFilterAll').classList.remove('active');
            document.getElementById('btnFilterMedia').classList.remove('active');

            // Add active to the one clicked
            clickedBtn.classList.add('active');

            // Run the main filter engine
            applyFilters();
        }

        // --- PHOTO MODAL (LIGHTBOX) LOGIC ---
        let currentImageArray = [];
        let currentImageIndex = 0;

        function openPhotoModal(imageUrls) {
            currentImageArray = imageUrls;
            currentImageIndex = 0;
            updateModalView();
            document.getElementById('photoModal').style.display = "block";
        }

        function closeModal() {
            document.getElementById('photoModal').style.display = "none";
        }

        function changePhoto(direction) {
            currentImageIndex += direction;
            if (currentImageIndex >= currentImageArray.length) currentImageIndex = 0;
            else if (currentImageIndex < 0) currentImageIndex = currentImageArray.length - 1;

            updateModalView();
        }

        function updateModalView() {
            document.getElementById('modalImage').src = currentImageArray[currentImageIndex];
            document.getElementById('imageCounter').innerText = (currentImageIndex + 1) + " / " + currentImageArray.length;

            const controls = document.querySelector('.modal-controls');
            if (currentImageArray.length <= 1) {
                controls.style.display = "none";
            } else {
                controls.style.display = "flex";
            }
        }

        window.onclick = function(event) {
            const modal = document.getElementById('photoModal');
            if (event.target == modal) {
                closeModal();
            }
        }
    </script>
</body>
</html>

