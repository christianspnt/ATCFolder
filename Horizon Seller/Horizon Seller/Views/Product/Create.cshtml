@{
    ViewData["Title"] = "Manage Product Listing";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Manage Product Listing</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --main-bg: #ffffff;
            --input-bg: #AFAFB3;
            --text-dark: #111;
            --accent-red: #c5221f;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            color: var(--text-dark);
        }

        /* Top Navigation Menu */
        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            border-bottom: 1px solid #eee;
        }

        .logo {
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        /* Main Container */
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 100px 20px;
        }

        h2.page-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        /* Image Upload Section */
        .main-upload-box {
            width: 100%;
            height: 350px;
            background-color: var(--input-bg);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 15px;
            cursor: pointer;
            margin-bottom: 20px;
            transition: 0.2s;
        }

            .main-upload-box:hover {
                background-color: #a0a0a5;
            }

            .main-upload-box i {
                font-size: 6rem;
                color: #444;
            }
            
            .main-upload-box span {
                font-size: 1.4rem;
                font-weight: 600;
                color: #222;
            }

        /* Thumbnail Row */
        .thumbnail-row {
            display: flex;
            gap: 15px;
            margin-bottom: 40px;
            overflow-x: auto;
            padding: 10px 0;
        }

            .thumbnail-row::-webkit-scrollbar {
                height: 6px;
            }
            .thumbnail-row::-webkit-scrollbar-track {
                background: transparent;
            }
            .thumbnail-row::-webkit-scrollbar-thumb {
                background: #bbb;
                border-radius: 10px;
            }
                .thumbnail-row::-webkit-scrollbar-thumb:hover {
                    background: #888;
                }

        .thumbnail {
            width: 85px;
            height: 85px;
            background-color: var(--input-bg);
            border-radius: 10px;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

            .thumbnail img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* Delete Button on Hover */
        .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            border: none;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
        }

            .delete-btn:hover {
                background: var(--accent-red);
            }

        .thumbnail:hover .delete-btn {
            display: flex;
        }

        /* Form Details */
        h3.section-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .form-row {
            margin-bottom: 15px;
        }

        .custom-input {
            width: 100%;
            background-color: var(--input-bg);
            border: none;
            padding: 20px 25px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #222;
            box-sizing: border-box;
            outline: none;
        }

            .custom-input::placeholder {
                color: #444;
                font-weight: 400;
            }

        /* Price / Discount Flex Row */
        .split-input-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--input-bg);
            border-radius: 12px;
            padding: 5px 25px;
        }

            .split-input-box input {
                background: transparent;
                border: none;
                font-family: 'Inter', sans-serif;
                font-size: 1.05rem;
                padding: 15px 0;
                outline: none;
                color: #222;
            }
            
            /* Remove up/down arrows from number inputs */
            .split-input-box input[type="number"]::-webkit-outer-spin-button,
            .split-input-box input[type="number"]::-webkit-inner-spin-button {
                -webkit-appearance: none;
                margin: 0;
            }
            .split-input-box input[type="number"] {
                -moz-appearance: textfield;
            }

                .split-input-box input::placeholder {
                    color: #444;
                }

        .discount-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .discount-wrap input {
                width: 60px;
                text-align: left;
            }

        /* Variant Row */
        .variant-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .btn-plus-square {
            width: 55px;
            height: 55px;
            background-color: var(--input-bg);
            border: none;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #333;
            cursor: pointer;
            flex-shrink: 0;
            overflow: hidden;
            padding: 0;
        }

            .btn-plus-square:hover {
                background-color: #a0a0a5;
            }

        .small-input {
            background-color: var(--input-bg);
            border: none;
            padding: 18px 15px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: #222;
            outline: none;
            flex: 1;
            min-width: 70px;
        }

            .small-input::placeholder {
                color: #444;
            }

        .availability-label {
            font-weight: 700;
            margin-left: 5px;
            margin-right: 5px;
        }

        /* Interactive Custom Radio Styling */
        .custom-radio {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-weight: 500;
            user-select: none;
            font-size: 0.9rem;
        }

            .custom-radio input {
                display: none;
            }

        .radio-box {
            width: 25px;
            height: 25px;
            background-color: var(--input-bg);
            border-radius: 6px;
            transition: background-color 0.2s;
        }

        .custom-radio input:checked + .radio-box {
            background-color: #000;
        }

        /* Add Size & Style Button Row */
        .add-variant-row {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 15px;
        }

        .btn-add-variant {
            flex: 1;
            background-color: var(--input-bg);
            border: none;
            padding: 20px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #333;
            cursor: pointer;
            text-align: center;
        }

            .btn-add-variant:hover {
                background-color: #a0a0a5;
            }

        .size-guide {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            width: 80px;
            text-decoration: none;
            color: inherit;
        }

            .size-guide i {
                font-size: 1.6rem;
                margin-top: 4px;
            }

        /* Text Area */
        textarea.custom-input {
            height: 180px;
            resize: none;
        }

        /* Action Buttons */
        .action-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 20px;
        }

        .btn-submit {
            background-color: #1a1a1a;
            color: #fff;
            border: none;
            padding: 20px 60px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-submit:hover {
                background-color: #000;
            }

        .btn-cancel {
            background-color: #fff;
            color: #111;
            border: 1px solid #111;
            padding: 20px 60px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-cancel:hover {
                background-color: #f5f5f5;
            }

        /* Modal */
        .overlay-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .overlay-content {
            background: #fff;
            padding: 30px;
            border-radius: 16px;
            max-width: 600px;
            width: 90%;
            text-align: center;
        }

            .overlay-content h3 {
                margin-top: 0;
                margin-bottom: 20px;
            }

        .grid-selector {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
            max-height: 400px;
            overflow-y: auto;
        }

            .grid-selector img {
                width: 100%;
                aspect-ratio: 1;
                object-fit: cover;
                border-radius: 10px;
                cursor: pointer;
                border: 2px solid transparent;
            }

                .grid-selector img:hover {
                    border-color: #111;
                }

        .close-modal {
            background: #111;
            color: #fff;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <header class="top-nav">
        <div class="logo">
            <div style="background: black; color: white; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <div class="nav-actions">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </div>
    </header>

    <div class="container">
        <h2 class="page-title" id="dynamic-page-title">Create Product Listing</h2>

        <input type="file" id="imageInput" multiple accept="image/*" style="display: none;">

        <div class="main-upload-box" id="uploadBox">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Upload Photos</span>
        </div>

        <div class="thumbnail-row" id="thumbnailRow">
        </div>

        <h3 class="section-title">Product Details</h3>

        <div class="form-row">
            <input type="text" class="custom-input" placeholder="Product Name">
        </div>

        <div class="form-row" style="margin-bottom: 5px;">
            <div class="split-input-box">
                <input type="number" id="basePrice" placeholder="Price" min="0" step="any">
                <div class="discount-wrap">
                    <span style="color: #444;">Discount % |</span>
                    <input type="number" id="discountPercent" placeholder="0" min="0" max="100">
                </div>
            </div>
            <div style="text-align: right; font-size: 0.95rem; color: #555; padding-right: 10px; margin-top: 8px;">
                Final Price: <span id="finalPriceDisplay" style="font-weight: 700; color: #111;">0.00</span>
            </div>
        </div>

        <div class="form-row">
            <input list="category-options" class="custom-input" name="category" placeholder="Search or select a Category...">
            <datalist id="category-options">
                <option value="Tops" />
                <option value="Bottoms" />
                <option value="Outerwear" />
                <option value="Dresses & Jumpsuits" />
                <option value="Activewear" />
                <option value="Footwear" />
                <option value="Accessories" />
            </datalist>
        </div>

        <div id="variants-container">
            <div class="variant-row">
                <button class="btn-plus-square"><i class="fa-solid fa-plus" style="font-weight: 300;"></i></button>
                <input type="text" class="small-input sku-field" placeholder="SKU |">
                <input type="text" class="small-input" placeholder="Size |">
                <input type="text" class="small-input" placeholder="Style |">
                <input type="text" class="small-input" placeholder="Quantity |">

                <span class="availability-label">Availability</span>

                <label class="custom-radio">
                    <input type="radio" name="availability-0" checked>
                    <div class="radio-box"></div>
                    In Stock
                </label>
                <label class="custom-radio">
                    <input type="radio" name="availability-0">
                    <div class="radio-box"></div>
                    Pre Order
                </label>
            </div>
        </div>

        <div class="add-variant-row">
            <button class="btn-add-variant" id="btnAddVariant">Add Size & Style</button>
            <a href="/Product/sizeguide" class="size-guide">
                Size Guide
                <i class="fa-solid fa-ruler-horizontal"></i>
            </a>
        </div>

        <div class="form-row">
            <textarea class="custom-input" placeholder="Product Details"></textarea>
        </div>

        <div class="action-buttons">
            <button class="btn-cancel" onclick="window.history.back()">Cancel</button>
            <button class="btn-submit" id="dynamic-submit-btn">Add Product</button>
        </div>
    </div>

    <div class="overlay-modal" id="imageModal">
        <div class="overlay-content">
            <h3>Select Variant Image</h3>
            <div class="grid-selector" id="modalGrid">
            </div>
            <button class="close-modal" onclick="document.getElementById('imageModal').style.display='none'">Close</button>
        </div>
    </div>

    <script>
        // 0. Dynamic Page Logic 
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const mode = urlParams.get('mode');
            
            const pageTitle = document.getElementById('dynamic-page-title');
            const submitBtn = document.getElementById('dynamic-submit-btn');

            if (mode === 'edit') {
                pageTitle.innerText = 'Edit Product Listing';
                submitBtn.innerText = 'Update Product';
            } else if (mode === 'renew') {
                pageTitle.innerText = 'Renew Product Listing';
                submitBtn.innerText = 'Renew Product';
            } else if (mode === 'relist') {
                pageTitle.innerText = 'Relist Product Listing';
                submitBtn.innerText = 'Relist Product';
            } else {
                pageTitle.innerText = 'Create Product Listing';
                submitBtn.innerText = 'Add Product';
            }

            const firstSkuField = document.querySelector('.sku-field');
            if(firstSkuField && !firstSkuField.value) {
                firstSkuField.value = generateSKU();
            }
        });

        function generateSKU() {
            return 'SKU-' + Math.random().toString(36).substr(2, 6).toUpperCase();
        }

        // --- NEW: Price and Discount Logic ---
        const priceInput = document.getElementById('basePrice');
        const discountInput = document.getElementById('discountPercent');
        const finalPriceDisplay = document.getElementById('finalPriceDisplay');

        // Block 'e', '+', '-' on number inputs
        function blockInvalidNumberInput(e) {
            if (['e', 'E', '+', '-'].includes(e.key)) {
                e.preventDefault();
            }
        }
        
        // Calculate the Final Discounted Price visually
        function calculateFinalPrice() {
            let price = parseFloat(priceInput.value) || 0;
            let discount = parseFloat(discountInput.value) || 0;

            // Cap discount at 100%
            if (discount > 100) {
                discount = 100;
                discountInput.value = 100;
            }

            const finalPrice = price - (price * (discount / 100));
            finalPriceDisplay.innerText = finalPrice.toFixed(2);
        }

        priceInput.addEventListener('keydown', blockInvalidNumberInput);
        discountInput.addEventListener('keydown', blockInvalidNumberInput);
        priceInput.addEventListener('input', calculateFinalPrice);
        discountInput.addEventListener('input', calculateFinalPrice);

        // 1. Image Upload & Display Logic
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');
        let uploadedImages = []; 

        uploadBox.addEventListener('click', () => {
            imageInput.click();
        });

        imageInput.addEventListener('change', function(event) {
            const files = event.target.files;
            for (let i = 0; i < files.length; i++) {
                const imageUrl = URL.createObjectURL(files[i]);
                uploadedImages.push(imageUrl);

                const thumbDiv = document.createElement('div');
                thumbDiv.className = 'thumbnail';
                thumbDiv.innerHTML = `
                    <img src="${imageUrl}" alt="Uploaded Photo">
                    <button class="delete-btn" onclick="removeThumbnail(this, '${imageUrl}')">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                thumbnailRow.appendChild(thumbDiv);
            }
            imageInput.value = '';
        });

        window.removeThumbnail = function(button, url) {
            uploadedImages = uploadedImages.filter(img => img !== url);
            button.parentElement.remove();
        };


        // 2. Dynamic Variant Row Logic
        const btnAddVariant = document.getElementById('btnAddVariant');
        const variantsContainer = document.getElementById('variants-container');
        let variantIdCounter = 0; // Ensures each row gets unique radio button groups

        btnAddVariant.addEventListener('click', () => {
            variantIdCounter++;
            const newRow = document.createElement('div');
            newRow.className = 'variant-row';
            const newSku = generateSKU();
            
            newRow.innerHTML = `
                <button class="btn-plus-square"><i class="fa-solid fa-plus" style="font-weight: 300;"></i></button>
                <input type="text" class="small-input sku-field" value="${newSku}" placeholder="SKU |">
                <input type="text" class="small-input" placeholder="Size |">
                <input type="text" class="small-input" placeholder="Style |">
                <input type="text" class="small-input" placeholder="Quantity |">

                <span class="availability-label">Availability</span>

                <label class="custom-radio">
                    <input type="radio" name="availability-${variantIdCounter}" checked>
                    <div class="radio-box"></div>
                    In Stock
                </label>
                <label class="custom-radio">
                    <input type="radio" name="availability-${variantIdCounter}">
                    <div class="radio-box"></div>
                    Pre Order
                </label>

                <button onclick="this.parentElement.remove()" style="background:none; border:none; color:var(--accent-red); font-size:1.2rem; cursor:pointer; margin-left: 5px;">
                    <i class="fa-solid fa-trash"></i>
                </button>
            `;
            variantsContainer.appendChild(newRow);
        });

        // 3. Select Picture for specific variant Logic
        const imageModal = document.getElementById('imageModal');
        const modalGrid = document.getElementById('modalGrid');
        let currentVariantBtn = null; 

        variantsContainer.addEventListener('click', function(e) {
            const btn = e.target.closest('.btn-plus-square');
            if (btn) {
                currentVariantBtn = btn;
                openImageSelector();
            }
        });

        function openImageSelector() {
            modalGrid.innerHTML = ''; 

            if (uploadedImages.length === 0) {
                modalGrid.innerHTML = '<p style="grid-column: 1 / -1; color: #555;">Please upload some photos first using the big cloud box above.</p>';
            } else {
                uploadedImages.forEach(url => {
                    const img = document.createElement('img');
                    img.src = url;
                    img.onclick = () => {
                        currentVariantBtn.innerHTML = `<img src="${url}" style="width:100%; height:100%; object-fit:cover;">`;
                        imageModal.style.display = 'none';
                    };
                    modalGrid.appendChild(img);
                });
            }
            imageModal.style.display = 'flex';
        }
    </script>

</body>
</html>

