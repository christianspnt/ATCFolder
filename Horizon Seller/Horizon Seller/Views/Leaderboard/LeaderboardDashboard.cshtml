@{
    ViewData["Title"] = "Leaderboard Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/leaderboarddashboard.css">
</head>
<body>

    <section class="top-section">
        <div class="hero-podium-wrapper">
            <div class="hero-text">
                <h1>CHAMPIONS</h1>
                <h2>Train hard. Stay focused.</h2>
                <p>Progress is built daily.</p>
            </div>

            <div class="podium-container">
                <div class="podium-pillar second">
                    <img src="https://i.pravatar.cc/150?img=32" alt="Alexandra" class="podium-avatar story-trigger" data-id="2">
                    <div class="podium-info">
                        <h3>ALEXANDRA EALA</h3>
                        <p>5.11 KM Distance</p>
                    </div>
                </div>

                <div class="podium-pillar first">
                    <img src="https://i.pravatar.cc/150?img=11" alt="Cristiano" class="podium-avatar story-trigger" data-id="1">
                    <div class="podium-info">
                        <h3>CRISTIANO RONALDO</h3>
                        <p>7.09KM Distance</p>
                    </div>
                </div>

                <div class="podium-pillar third">
                    <img src="https://i.pravatar.cc/150?img=12" alt="Carlos" class="podium-avatar story-trigger" data-id="3">
                    <div class="podium-info">
                        <h3>CARLOS YULO</h3>
                        <p>5.02KM Distance</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="toggle-container">
            <a href="#" class="toggle-btn outline">REGION</a>
            <a href="#" class="toggle-btn filled">NATIONAL</a>
        </div>
    </section>

    <section class="leaderboard-section">
        <h2>LEADERBOARD</h2>

        <div class="scrolling-wrapper">
            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">1st</div>
                    <img src="https://images.unsplash.com/photo-1551632811-561732d1e306?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image story-trigger" data-id="1">
                    <img src="https://i.pravatar.cc/150?img=11" alt="Profile" class="card-avatar story-trigger" data-id="1">
                </div>
                <div class="card-nameplate">CRISTIANO RONALDO</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">2nd</div>
                    <img src="https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image story-trigger" data-id="2">
                    <img src="https://i.pravatar.cc/150?img=32" alt="Profile" class="card-avatar story-trigger" data-id="2">
                </div>
                <div class="card-nameplate">ALEXANDRA EALA</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">3rd</div>
                    <img src="https://images.unsplash.com/photo-1530143311094-34d807799e8f?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image story-trigger" data-id="3">
                    <img src="https://i.pravatar.cc/150?img=12" alt="Profile" class="card-avatar story-trigger" data-id="3">
                </div>
                <div class="card-nameplate">CARLOS YULO</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">4th</div>
                    <img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image story-trigger" data-id="4">
                    <img src="https://i.pravatar.cc/150?img=15" alt="Profile" class="card-avatar story-trigger" data-id="4">
                </div>
                <div class="card-nameplate">MANNY P</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">4th</div>
                    <img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image story-trigger" data-id="4">
                    <img src="https://i.pravatar.cc/150?img=15" alt="Profile" class="card-avatar story-trigger" data-id="4">
                </div>
                <div class="card-nameplate">MANNY P</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">4th</div>
                    <img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image story-trigger" data-id="4">
                    <img src="https://i.pravatar.cc/150?img=15" alt="Profile" class="card-avatar story-trigger" data-id="4">
                </div>
                <div class="card-nameplate">MANNY P</div>
            </div>
        </div>

        <a href="/Leaderboard/viewallboard" class="view-all-link">VIEW ALL</a>
    </section>

    <section class="upload-section">
        <a href="/Leaderboard/uploadtracker" class="upload-btn">UPLOAD YOURS NOW</a>
    </section>

    <div class="story-modal" id="storyViewer">
        <div class="story-header">
            <button id="closeStory" class="close-btn"><i class="fas fa-times"></i></button>

            <a href="profile.cshtml" class="story-profile">
                <img src="" alt="Profile" class="story-avatar">
                <span class="story-name"></span>
            </a>
        </div>

        <div class="story-container">
            <div class="story-body">
                <img src="" alt="Story Image" class="story-main-image">
                <div class="story-data">
                    <div class="data-item"><span class="label">Distance</span><span class="value" id="modalDist"></span></div>
                    <div class="data-item"><span class="label">pace</span><span class="value" id="modalPace"></span></div>
                    <div class="data-item"><span class="label">Time</span><span class="value" id="modalTime"></span></div>
                </div>
                <div class="strava-section">
                    <div class="strava-route-squiggle"></div>
                    <div class="strava-text">NEXT HORIZON</div>
                </div>
            </div>
            <div class="story-navigation">
                <div class="nav-hitbox left" id="prevStory"></div>
                <div class="nav-hitbox right" id="nextStory"></div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // --- 1. INFINITE SCROLL ---
            const wrapper = document.querySelector('.scrolling-wrapper');
            const cards = Array.from(wrapper.children);
            cards.forEach(card => {
                let clone = card.cloneNode(true);
                wrapper.appendChild(clone);
            });
            wrapper.addEventListener('scroll', () => {
                const halfwayPoint = wrapper.scrollWidth / 2;
                if (wrapper.scrollLeft >= halfwayPoint) {
                    wrapper.scrollLeft = wrapper.scrollLeft - halfwayPoint;
                }
            });

            // --- 2. STORY VIEWER LOGIC ---

            // This acts as our "Database" for the frontend UI test
            const stories = [
                { id: "1", name: "CRISTIANO RONALDO", avatar: "https://i.pravatar.cc/150?img=11", img: "https://images.unsplash.com/photo-1551632811-561732d1e306?q=80&w=400&auto=format&fit=crop", dist: "7.09 km", pace: "4:59/km", time: "35m 22s" },
                { id: "2", name: "ALEXANDRA EALA", avatar: "https://i.pravatar.cc/150?img=32", img: "https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?q=80&w=400&auto=format&fit=crop", dist: "5.11 km", pace: "6:03/km", time: "30m 57s" },
                { id: "3", name: "CARLOS YULO", avatar: "https://i.pravatar.cc/150?img=12", img: "https://images.unsplash.com/photo-1530143311094-34d807799e8f?q=80&w=400&auto=format&fit=crop", dist: "5.02 km", pace: "6:26/km", time: "33m 40s" },
                { id: "4", name: "MANNY P", avatar: "https://i.pravatar.cc/150?img=15", img: "https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop", dist: "5.01 km", pace: "7:02/km", time: "35m 16s" }
            ];

            const modal = document.getElementById('storyViewer');
            let currentIndex = 0;

            function openStory(index) {
                if (index < 0) index = stories.length - 1; // Loop to end
                if (index >= stories.length) index = 0; // Loop to start

                currentIndex = index;
                const data = stories[currentIndex];

                document.querySelector('.story-avatar').src = data.avatar;
                document.querySelector('.story-name').textContent = data.name;
                document.querySelector('.story-main-image').src = data.img;
                document.getElementById('modalDist').textContent = data.dist;
                document.getElementById('modalPace').textContent = data.pace;
                document.getElementById('modalTime').textContent = data.time;

                modal.style.display = 'block';
            }

            // Add click events to images
            document.querySelectorAll('.story-trigger').forEach(trigger => {
                trigger.addEventListener('click', (e) => {
                    const id = e.target.getAttribute('data-id');
                    const index = stories.findIndex(s => s.id === id);
                    if (index !== -1) openStory(index);
                });
            });

            // Nav buttons
            document.getElementById('prevStory').addEventListener('click', () => openStory(currentIndex - 1));
            document.getElementById('nextStory').addEventListener('click', () => openStory(currentIndex + 1));

            // Close button (will now work properly!)
            document.getElementById('closeStory').addEventListener('click', () => { modal.style.display = 'none'; });
        });
    </script>
</body>
</html>


