@{
    ViewData["Title"] = "Product Size Guide";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Product Size Guide</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/sizeguide.css">

</head>
<body>

    <header class="top-nav">
        <div class="logo">
            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c2/GitHub_Invertocat_Logo.svg/1200px-GitHub_Invertocat_Logo.svg.png" style="width:24px" alt="logo">
            HORIZON
        </div>
        <div class="nav-actions">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </div>
    </header>

    <div class="container">
        <h2 class="page-title">Product Size Guide</h2>

        <input type="text" class="custom-input" placeholder="Size Guide Title">

        <input type="file" id="imageInput" multiple accept="image/*" style="display: none;">
        <div class="main-upload-box" id="uploadBox">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Upload Photos</span>
        </div>

        <span class="upload-label">Upload Size Guide</span>
        <div class="thumbnail-row" id="thumbnailRow"></div>

        <div class="divider-container">
            <span>OR</span>
        </div>

        <h2 class="page-title" style="margin-bottom: 15px;">Create Size Guide</h2>

        <div class="select-row">
            <select class="custom-input custom-select">
                <option value="" disabled selected>Measurement Unit</option>
                <option value="cm">Centimeters (cm)</option>
                <option value="in">Inches (in)</option>
            </select>
            <select class="custom-input custom-select">
                <option value="" disabled selected>Category</option>
                <option value="Tops">Tops</option>
                <option value="Bottoms">Bottoms</option>
                <option value="Footwear">Footwear</option>
                <option value="Outerwear">Outerwear</option>
                <option value="Dresses & Jumpsuits">Dresses & Jumpsuits</option>
                <option value="Activewear">Activewear</option>
                <option value="Accessories">Accesories</option>
            </select>
        </div>

        <button class="btn-create-table" id="btnShowCreateTableModal">Create Table</button>

        <div id="dynamic-tables-container">
        </div>

        <h3 style="margin-top: 30px; margin-bottom: 15px; font-size: 1.2rem;">Additional Information</h3>
        <textarea class="custom-input" placeholder="Fit Tips (e.g., Fits true to size, take your normal size.)"></textarea>
        <textarea class="custom-input" placeholder="How to Measure (e.g., Chest: Measure around the fullest part of your chest...)"></textarea>
        <textarea class="custom-input" placeholder="Additional Notes or Details (Optional)"></textarea>

        <div class="action-buttons">
            <button class="btn-submit">Save Size Guide</button>
        </div>
    </div>

    <div class="overlay-modal" id="createTableModal">
        <div class="overlay-content">
            <h3>Table Dimensions</h3>
            <p style="color: #666; margin-bottom: 20px; font-size: 0.9rem;">How many columns and rows do you need?</p>
            <div class="modal-inputs">
                <input type="number" id="colCountInput" placeholder="Columns" min="1" value="5">
                <input type="number" id="rowCountInput" placeholder="Rows" min="1" value="4">
            </div>
            <div class="modal-actions">
                <button class="btn-modal btn-cancel-modal" onclick="closeModal('createTableModal')">Cancel</button>
                <button class="btn-modal btn-confirm-modal" id="btnGenerateTable">Generate</button>
            </div>
        </div>
    </div>

    <div class="overlay-modal" id="deleteRowColModal">
        <div class="overlay-content">
            <h3>Delete Options</h3>
            <p style="color: #666; margin-bottom: 20px; font-size: 0.9rem;">What would you like to remove from this table?</p>
            <div class="modal-actions">
                <button class="btn-modal btn-cancel-modal" onclick="closeModal('deleteRowColModal')">Cancel</button>
                <button class="btn-modal btn-danger-modal" id="btnConfirmDeleteRow">Delete Row</button>
                <button class="btn-modal btn-danger-modal" id="btnConfirmDeleteCol">Delete Column</button>
                <button class="btn-modal btn-delete-entire" id="btnConfirmDeleteTable">Delete Entire Table</button>
            </div>
            <p id="deleteWarning" style="color: var(--accent-red); font-size: 0.85rem; margin-top: 15px; display: none;">Cannot delete the last remaining row/column!</p>
        </div>
    </div>


    <script>
        // --- 1. Image Upload Logic ---
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');

        uploadBox.addEventListener('click', () => imageInput.click());

        imageInput.addEventListener('change', function(event) {
            const files = event.target.files;
            for (let i = 0; i < files.length; i++) {
                const imageUrl = URL.createObjectURL(files[i]);
                const thumbDiv = document.createElement('div');
                thumbDiv.className = 'thumbnail';
                thumbDiv.innerHTML = `
                    <img src="${imageUrl}" alt="Uploaded Photo">
                    <button class="delete-btn" onclick="this.parentElement.remove()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                thumbnailRow.appendChild(thumbDiv);
            }
            imageInput.value = '';
        });


        // --- 2. Modal Utility Functions ---
        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
            document.getElementById('deleteWarning').style.display = 'none';
        }


        // --- 3. Dynamic Table Generation Logic ---
        const btnShowCreateTableModal = document.getElementById('btnShowCreateTableModal');
        const btnGenerateTable = document.getElementById('btnGenerateTable');
        const tablesContainer = document.getElementById('dynamic-tables-container');

        let targetTableForDeletion = null;

        btnShowCreateTableModal.addEventListener('click', () => {
            openModal('createTableModal');
        });

        btnGenerateTable.addEventListener('click', () => {
            const cols = parseInt(document.getElementById('colCountInput').value) || 5;
            const rows = parseInt(document.getElementById('rowCountInput').value) || 4;

            createDynamicTable(rows, cols);
            closeModal('createTableModal');
        });

        function createDynamicTable(rows, cols) {
            const wrapper = document.createElement('div');
            wrapper.className = 'table-wrapper';

            // NEW: Table Title Input Field
            const titleInputHTML = `<input type="text" class="custom-input" placeholder="Table Title" style="margin-bottom: 10px; padding: 15px 25px; font-weight: 600;">`;

            const addColBtn = `<button class="corner-btn btn-add-col" title="Add Column"><i class="fa-solid fa-plus"></i></button>`;
            const addRowBtn = `<button class="corner-btn btn-add-row" title="Add Row"><i class="fa-solid fa-plus"></i></button>`;
            const delRcBtn = `<button class="corner-btn btn-delete-rc" title="Delete Options"><i class="fa-solid fa-xmark"></i></button>`;

            // Inner wrapper handles the border-radius safely without messing up table cell borders
            let tableHTML = `<div class="table-inner-wrapper"><table class="size-guide-table"><tbody>`;
            for (let r = 0; r < rows; r++) {
                tableHTML += `<tr>`;
                for (let c = 0; c < cols; c++) {
                    tableHTML += `<td><input type="text"></td>`;
                }
                tableHTML += `</tr>`;
            }
            tableHTML += `</tbody></table></div>`;

            // Putting the table and buttons inside a relative container so corner buttons align correctly
            wrapper.innerHTML = titleInputHTML + `<div style="position: relative;">` + addColBtn + addRowBtn + delRcBtn + tableHTML + `</div>`;
            tablesContainer.appendChild(wrapper);
        }

        // --- 4. Table Interaction Logic ---
        tablesContainer.addEventListener('click', function(e) {
            const target = e.target.closest('.corner-btn');
            if (!target) return;

            const wrapper = target.closest('.table-wrapper');
            const tableBody = wrapper.querySelector('tbody');
            const rows = tableBody.querySelectorAll('tr');

            // Add Column
            if (target.classList.contains('btn-add-col')) {
                rows.forEach(row => {
                    const newCell = document.createElement('td');
                    newCell.innerHTML = `<input type="text">`;
                    row.appendChild(newCell);
                });
            }

            // Add Row
            if (target.classList.contains('btn-add-row')) {
                const colCount = rows[0].querySelectorAll('td').length;
                const newRow = document.createElement('tr');
                for (let i = 0; i < colCount; i++) {
                    const newCell = document.createElement('td');
                    newCell.innerHTML = `<input type="text">`;
                    newRow.appendChild(newCell);
                }
                tableBody.appendChild(newRow);
            }

            // Delete Options -> Opens Modal
            if (target.classList.contains('btn-delete-rc')) {
                targetTableForDeletion = tableBody;
                openModal('deleteRowColModal');
            }
        });

        // --- 5. Delete Modal Action Logic ---
        document.getElementById('btnConfirmDeleteRow').addEventListener('click', () => {
            if (!targetTableForDeletion) return;
            const rows = targetTableForDeletion.querySelectorAll('tr');

            if (rows.length <= 1) {
                document.getElementById('deleteWarning').style.display = 'block';
                return;
            }

            targetTableForDeletion.removeChild(rows[rows.length - 1]);
            closeModal('deleteRowColModal');
        });

        document.getElementById('btnConfirmDeleteCol').addEventListener('click', () => {
            if (!targetTableForDeletion) return;
            const rows = targetTableForDeletion.querySelectorAll('tr');

            const colCount = rows[0].querySelectorAll('td').length;
            if (colCount <= 1) {
                document.getElementById('deleteWarning').style.display = 'block';
                return;
            }

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                row.removeChild(cells[cells.length - 1]);
            });
            closeModal('deleteRowColModal');
        });

        // NEW: Delete Entire Table Logic
        document.getElementById('btnConfirmDeleteTable').addEventListener('click', () => {
            if (!targetTableForDeletion) return;

            // Finds the main wrapper for the specific table and removes it entirely
            const entireTableWrapper = targetTableForDeletion.closest('.table-wrapper');
            if(entireTableWrapper) {
                entireTableWrapper.remove();
            }
            closeModal('deleteRowColModal');
        });

    </script>
</body>
</html>

