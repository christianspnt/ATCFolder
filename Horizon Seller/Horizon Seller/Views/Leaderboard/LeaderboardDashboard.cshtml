@{
    ViewData["Title"] = "Leaderboard Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="stylesheet" href="~/css/leaderboarddashboard.css">
</head>
<body>

    <section class="top-section">
        <div class="hero-podium-wrapper">
            <div class="hero-text">
                <h1>CHAMPIONS</h1>
                <h2>Train hard. Stay focused.</h2>
                <p>Progress is built daily.</p>
            </div>

            <div class="podium-container">
                <div class="podium-pillar second">
                    <img src="https://i.pravatar.cc/150?img=32" alt="Alexandra" class="podium-avatar">
                    <div class="podium-info">
                        <h3>ALEXANDRA EALA</h3>
                        <p>5.11 KM Distance</p>
                    </div>
                </div>

                <div class="podium-pillar first">
                    <img src="https://i.pravatar.cc/150?img=11" alt="Cristiano" class="podium-avatar">
                    <div class="podium-info">
                        <h3>CRISTIANO RONALDO</h3>
                        <p>7.09KM Distance</p>
                    </div>
                </div>

                <div class="podium-pillar third">
                    <img src="https://i.pravatar.cc/150?img=12" alt="Carlos" class="podium-avatar">
                    <div class="podium-info">
                        <h3>CARLOS YULO</h3>
                        <p>5.02KM Distance</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="toggle-container">
            <a href="#" class="toggle-btn outline">REGION</a>
            <a href="#" class="toggle-btn filled">NATIONAL</a>
        </div>
    </section>

    <section class="leaderboard-section">
        <h2>LEADERBOARD</h2>

        <div class="scrolling-wrapper">
            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">1st</div>
                    <img src="https://images.unsplash.com/photo-1551632811-561732d1e306?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image">
                    <img src="https://i.pravatar.cc/150?img=11" alt="Profile" class="card-avatar">
                </div>
                <div class="card-nameplate">CRISTIANO RONALDO</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">2nd</div>
                    <img src="https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image">
                    <img src="https://i.pravatar.cc/150?img=32" alt="Profile" class="card-avatar">
                </div>
                <div class="card-nameplate">ALEXANDRA EALA</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">3rd</div>
                    <img src="https://images.unsplash.com/photo-1530143311094-34d807799e8f?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image">
                    <img src="https://i.pravatar.cc/150?img=12" alt="Profile" class="card-avatar">
                </div>
                <div class="card-nameplate">CARLOS YULO</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">4th</div>
                    <img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image">
                    <img src="https://i.pravatar.cc/150?img=15" alt="Profile" class="card-avatar">
                </div>
                <div class="card-nameplate">MANNY P</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">4th</div>
                    <img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image">
                    <img src="https://i.pravatar.cc/150?img=15" alt="Profile" class="card-avatar">
                </div>
                <div class="card-nameplate">MANNY P</div>
            </div>

            <div class="card">
                <div class="card-image-wrapper">
                    <div class="card-rank">4th</div>
                    <img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" alt="Run Track" class="card-image">
                    <img src="https://i.pravatar.cc/150?img=15" alt="Profile" class="card-avatar">
                </div>
                <div class="card-nameplate">MANNY P</div>
            </div>

        </div>

        <a href="viewallboard.cshtml" class="view-all-link">VIEW ALL</a>
    </section>

    <section class="upload-section">
        <a href="uploadtrack.cshtml" class="upload-btn">UPLOAD YOURS NOW</a>
    </section>

</body>
</html>

