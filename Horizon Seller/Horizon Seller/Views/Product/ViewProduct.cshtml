@{
    ViewData["Title"] = "View Product";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - View Product</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/ViewProduct.css">

    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <div style="background: white; color: black; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <nav>
            <a href="#" class="nav-item"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-receipt"></i> Orders</a>
            <a href="#" class="nav-item active"><i class="fa-solid fa-bag-shopping"></i> Products</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-wallet"></i> Finances</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-chart-line"></i> Analytics</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
        </nav>
    </aside>

    <div class="main-wrapper">
        <header class="header">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </header>

        <div class="container">
            <a href="javascript:window.history.back()" class="back-btn"><i class="fa-solid fa-arrow-left"></i></a>

            <div class="gallery-container">
                <div class="click-zone zone-left" onclick="prevImage()"></div>
                <div class="click-zone zone-right" onclick="nextImage()"></div>
                <img id="mainGalleryImg" src="" alt="Product Image">
            </div>

            <div class="gallery-dots" id="galleryDots">
            </div>

            <h3 class="section-title">Product Details</h3>

            <div class="info-box">Nike Sportswear</div>

            <div class="info-box">₱4,795</div>

            <div class="info-box">Women's Oversized Windrunner Jacket</div>

            <div class="variant-bar">
                <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a" class="variant-thumb" alt="Thumb">

                <div class="variant-pill">
                    <span class="label">SKU</span>
                    <div class="divider"></div>
                    <span class="value" id="currentSkuValue">679724791648</span>
                </div>

                <div class="variant-pill">
                    <span class="label">Size</span>
                    <div class="divider"></div>
                    <span class="value">S</span>
                </div>

                <div class="variant-pill">
                    <span class="label">Style</span>
                    <div class="divider"></div>
                    <span class="value">Green</span>
                </div>

                <div class="variant-pill">
                    <span class="label">Quantity</span>
                    <div class="divider"></div>
                    <span class="value">756</span>
                </div>

                <span class="availability-label">Availability</span>

                <div class="radio-stack">
                    <div class="custom-radio">
                        <div class="radio-box box-active"></div>
                        In Stock
                    </div>
                    <div class="custom-radio">
                        <div class="radio-box box-inactive"></div>
                        Pre Order
                    </div>
                </div>
            </div>

            <div class="bottom-details">
                <div class="description-box">
                    This take on the Nike Windrunner has an extra-roomy fit, dropped shoulders and voluminous sleeves for a modern drape. The iconic chevron design lines are crafted with projecting edges for a decorative finish.
                    <ul>
                        <li>Colour Shown: Fir/Fir/Fir</li>
                        <li>Style: IF0271-323</li>
                        <li>Country/Region of Origin: China</li>
                    </ul>
                </div>

                <div class="barcode-box">
                    Nike Sportswear
                    <svg id="productBarcode"></svg>
                </div>
            </div>

            <div class="action-bar" id="actionBar">
                <button class="btn-action btn-delete" id="btnDelete" onclick="document.getElementById('deleteModal').style.display='flex'">Delete Product</button>
                <button class="btn-action btn-renew" id="btnRenew" onclick="window.location.href='/Product/Create?mode=renew'">Renew Product</button>
                <button class="btn-action btn-edit" id="btnEdit" onclick="window.location.href='/Product/Create?mode=edit'">Edit Product</button>
                <button class="btn-action btn-relist" id="btnRelist" onclick="window.location.href='/Product/Create?mode=relist'">Relist Product</button>
            </div>

        </div>
    </div>

    <div class="overlay-modal" id="deleteModal">
        <div class="delete-modal-content">
            <i class="fa-solid fa-trash" style="font-size: 4rem; color: #000; margin-bottom: 20px;"></i>
            <h2 style="margin: 0 0 15px 0; font-size: 1.8rem; font-weight: 700;">Delete Products</h2>
            <p style="margin: 0 0 30px 0; font-size: 1.1rem; color: #333;">Are you sure that you want to delete this product?</p>
            <div style="display: flex; gap: 15px; width: 100%;">
                <button class="btn-modal-outline" onclick="window.location.href='/Home/Index'">Delete Product</button>
                <button class="btn-modal-solid" onclick="document.getElementById('deleteModal').style.display='none'">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        /* --- JsBarcode Initialization --- */
        // Automatically generate barcode matching the SKU on load
        document.addEventListener('DOMContentLoaded', () => {
            const skuValue = document.getElementById("currentSkuValue").innerText;

            JsBarcode("#productBarcode", skuValue, {
                format: "CODE128",
                lineColor: "#000000",
                background: "transparent",
                width: 2,
                height: 55,
                displayValue: true,
                fontSize: 16,
                font: "Inter",
                margin: 0
            });
        });


        /* --- Image Gallery Logic --- */
        const galleryImages = [
            "https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a", // Front
            "https://images.unsplash.com/photo-1608228065096-7b4474776150", // Close up
            "https://images.unsplash.com/photo-1489987707023-afc82478163f", // Detail
            "https://images.unsplash.com/photo-1556821840-3a63f95609a7", // Extra
            "https://images.unsplash.com/photo-1515955656352-a1fa3ffcd111"  // 5th photo
        ];

        let currentImageIndex = 0;
        const mainGalleryImg = document.getElementById('mainGalleryImg');
        const dotsContainer = document.getElementById('galleryDots');

        function renderGallery() {
            mainGalleryImg.src = galleryImages[currentImageIndex];
            dotsContainer.innerHTML = '';
            const totalDots = Math.min(galleryImages.length, 4);

            let activeDotIndex = currentImageIndex;
            if (currentImageIndex >= 3 && galleryImages.length > 4) {
                activeDotIndex = 3;
            }

            for (let i = 0; i < totalDots; i++) {
                const dot = document.createElement('span');
                if (i === activeDotIndex) {
                    dot.classList.add('active');
                }
                dotsContainer.appendChild(dot);
            }
        }

        function nextImage() {
            if (galleryImages.length > 0) {
                currentImageIndex = (currentImageIndex + 1) % galleryImages.length;
                renderGallery();
            }
        }

        function prevImage() {
            if (galleryImages.length > 0) {
                currentImageIndex = (currentImageIndex - 1 + galleryImages.length) % galleryImages.length;
                renderGallery();
            }
        }

        /* --- Dynamic Button Logic based on URL State --- */
        document.addEventListener('DOMContentLoaded', () => {
            renderGallery();

            const urlParams = new URLSearchParams(window.location.search);
            const state = urlParams.get('state');

            const actionBar = document.getElementById('actionBar');
            const btnDelete = document.getElementById('btnDelete');
            const btnRenew = document.getElementById('btnRenew');
            const btnEdit = document.getElementById('btnEdit');
            const btnRelist = document.getElementById('btnRelist');

            btnDelete.style.display = 'none';
            btnRenew.style.display = 'none';
            btnEdit.style.display = 'none';
            btnRelist.style.display = 'none';

            if (state === 'renew') {
                btnDelete.style.display = 'block';
                btnRenew.style.display = 'block';
            } else if (state === 'relist') {
                actionBar.style.justifyContent = 'flex-end';
                btnRelist.style.display = 'block';
                btnRelist.style.flex = '0 0 48%';
            } else {
                btnDelete.style.display = 'block';
                btnEdit.style.display = 'block';
            }
        });
    </script>

</body>
</html>

