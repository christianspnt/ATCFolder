@{
    ViewData["Title"] = "Manage Products";
    Layout = null;
    // We can keep these variables, but the actual counts are now dynamically updated by JavaScript
    // based on how many products are actually in the containers!
    var activeCount = 0;
    var renewCount = 0;
    var relistCount = 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Manage Products</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --sidebar-bg: #000000;
            --main-bg: #ffffff;
            --list-bg: #EAE6E4; /* Updated to match the soft gray/beige in the image */
            --accent-green: #1a8a3d;
            --accent-yellow: #f2a900;
            --accent-red: #c5221f;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            display: flex;
            min-height: 100vh;
            color: #1a1a1a;
        }

        /* Sidebar Navigation */
        .sidebar {
            width: 260px;
            background-color: var(--sidebar-bg);
            color: #ffffff;
            display: flex;
            flex-direction: column;
            padding: 30px 20px;
            position: fixed;
            height: 100vh;
            z-index: 100;
        }

        .logo {
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 14px 15px;
            color: #999;
            text-decoration: none;
            transition: 0.3s;
            font-weight: 500;
            font-size: 1.1rem;
        }

            .nav-item i {
                margin-right: 15px;
                width: 24px;
                font-size: 1.2rem;
            }

            .nav-item:hover {
                color: #fff;
            }

            .nav-item.active {
                background-color: #333;
                color: #fff;
                border-radius: 10px;
            }

        /* Layout Adjustments */
        .main-wrapper {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
        }

        .header {
            height: 70px;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            padding: 0 50px;
            gap: 30px;
        }

        .content-container {
            padding: 50px 80px;
            max-width: 1200px;
        }

        /* Profile Header */
        .profile-section {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-bottom: 40px;
        }

        .profile-circle {
            width: 110px;
            height: 110px;
            border: 2px solid #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .profile-text h1 {
            font-size: 2.2rem;
            font-weight: 700;
            margin: 0;
        }

        .profile-text p {
            color: #666;
            margin-top: 5px;
            font-size: 1.1rem;
        }

        hr {
            border: 0;
            border-top: 1px solid #eee;
            margin: 30px 0;
        }

        /* Create Button */
        .btn-create {
            width: 100%;
            padding: 18px;
            background: #F6F5F5;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.12), 0px 1px 3px rgba(0, 0, 0, 0.08);
            border: none;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            margin-bottom: 50px;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-create:hover {
                background: #EBEBEB;
            }

        /* Overview Grid & Interactive Cards */
        .overview-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 15px;
            margin-bottom: 40px;
        }

        .overview-card {
            background: #F6F5F5;
            padding: 20px;
            border-radius: 14px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            user-select: none;
        }

            .overview-card:hover {
                background: #EDEDED;
            }

            .overview-card.active-card {
                background: #F6F5F5;
                box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.12), 0px 1px 3px rgba(0, 0, 0, 0.08);
            }

            .overview-card span {
                font-weight: 600;
                line-height: 1.2;
                font-size: 0.95rem;
            }

        .badge {
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            color: white;
            font-size: 0.75rem;
            font-weight: 700;
        }

        /* Product List Area */
        .product-box {
            background-color: var(--list-bg);
            border-radius: 18px;
            padding: 30px 40px;
            padding-bottom: 50px; /* added a bit more bottom padding */
        }

        .product-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .filter-dropdown {
            background: #8A8888;
            color: white;
            padding: 4px 12px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        /* Tab Content Logic */
        .product-group {
            display: none;
        }

            .product-group.visible {
                display: block;
            }

        .product-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
            border-bottom: none; /* Removed the line between items */
            margin: 20px;
            position: relative; /* For dropdown placement */
        }

        .product-detail {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .product-img {
            width: 90px;
            height: 90px;
            border-radius: 12px;
            object-fit: cover;
            background: white;
            transition: transform 0.2s; /* nice hover effect for images */
        }

            .product-img:hover {
                transform: scale(1.05);
            }

        .product-info a {
            text-decoration: none;
            color: inherit;
        }

        .product-info h4 {
            margin: 0;
            font-size: 1.05rem;
            font-weight: 600;
            color: #111;
        }

            .product-info h4:hover {
                text-decoration: underline;
            }

        .product-info p {
            margin: 4px 0 8px 0;
            font-size: 0.85rem;
            color: #555;
            font-weight: 400;
        }

        .price-wrap {
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .price-wrap .price {
                font-weight: 700;
                font-size: 0.9rem;
                color: #000;
            }

            .price-wrap .old-price {
                font-weight: 400;
                font-size: 0.8rem;
                color: #888;
                text-decoration: line-through;
            }

        /* Rating Pill Styles */
        .rating-pill {
            display: inline-flex;
            align-items: center;
            background: #969696;
            padding: 2px 8px;
            border-radius: 4px;
            margin-top: 6px;
            gap: 5px;
        }

            .rating-pill .stars {
                color: #111;
                font-size: 0.6rem;
                letter-spacing: 1px;
            }

            .rating-pill .review-text {
                color: #f0f0f0;
                font-size: 0.65rem;
                font-weight: 500;
            }

        /* Action Menu (Ellipses & Dropdown) */
        .action-menu-container {
            position: relative;
        }

        .btn-ellipses {
            background: transparent;
            border: none;
            font-size: 1.5rem;
            color: #555;
            cursor: pointer;
            padding: 5px 15px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .btn-ellipses:hover {
                color: #000;
            }

        .dropdown-menu {
            display: none;
            position: absolute;
            right: 0;
            top: 100%;
            background-color: #d1cfce; /* Matches the button backgrounds in your screenshot */
            border-radius: 6px;
            min-width: 130px;
            z-index: 50;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
            overflow: hidden;
            margin-top: 5px;
        }

            .dropdown-menu.show {
                display: block;
            }

        .dropdown-item {
            display: block;
            padding: 10px 15px;
            color: #000;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            text-align: center;
            border-bottom: 1px solid #bfbebc;
            transition: background 0.2s;
        }

            .dropdown-item:last-child {
                border-bottom: none;
            }

            .dropdown-item:hover {
                background-color: #b8b6b4; /* Slightly darker on hover */
            }


        /* Pagination Styling */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin-top: 40px;
            font-weight: 600;
            color: #888;
        }

        .page-active {
            color: #000;
            background: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.95rem;
        }

        .nav-arrow {
            font-size: 0.9rem;
        }

            .nav-arrow.disabled {
                color: #b0aba8;
                cursor: not-allowed;
            }
    </style>
</head>
